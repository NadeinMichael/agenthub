# === Database ===
DATABASE_URL=postgresql://agenthub:agenthub_password@localhost:5432/agenthub_db

# === Redis ===
REDIS_URL=redis://localhost:6379

# === API (NestJS) ===
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_EXPIRES_IN=7d

# === Web (Next.js) ===
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Groq ===
GROQ_API_KEY=gsk_3R...

# === Agent Executor ===
# Absolute path to the monorepo root — used by read_file / list_directory tools
AGENT_PROJECT_ROOT=/path/to/agenthub

# === Environment ===
NODE_ENV=development
